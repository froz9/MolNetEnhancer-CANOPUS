server <- function(input, output, session) {
v <- reactiveValues(logs = "Awaiting input...", final_csv = NULL, final_graph = NULL)
observeEvent(input$run_btn, {
req(input$graphml_file, input$canopus_file)
withProgress(message = 'Running MolNetEnhancer', value = 0, {
# --- Step 1: Parse GraphML ---
incProgress(0.1, detail = "Parsing GraphML...")
v$logs <- "Loading GraphML...\n"
g <- read_graph(input$graphml_file$datapath, format = "graphml")
comps <- components(g)
V(g)$componentindex <- comps$membership
singletons <- which(degree(g) == 0)
if(length(singletons) > 0) V(g)$componentindex[singletons] <- -1
net_df <- igraph::as_data_frame(g, what = "vertices")
if("id" %in% colnames(net_df)) {
net_df$cluster.index <- as.character(net_df$id)
} else {
v$logs <- paste0(v$logs, "Error: GraphML lacks 'id' attribute.\n")
return(NULL)
}
# --- Step 2: Query Hotspots ---
incProgress(0.1, detail = "Preparing Hotspot Queries...")
if("library_SMILES" %in% colnames(net_df)) {
unique_smiles <- unique(na.omit(net_df$library_SMILES[net_df$library_SMILES != ""]))
v$logs <- paste0(v$logs, "Found ", length(unique_smiles), " unique library SMILES.\n")
if (length(unique_smiles) > 0) {
api_results <- list()
n_smiles <- length(unique_smiles)
# Use a for loop to incrementally update the progress bar for the user
for(i in seq_along(unique_smiles)) {
incProgress(0.2 / n_smiles, detail = paste("Querying API:", i, "of", n_smiles))
api_results[[i]] <- query_npclassifier(unique_smiles[i])
}
api_df <- bind_rows(api_results)
net_df <- left_join(net_df, api_df, by = c("library_SMILES" = "SMILES"))
} else {
net_df$Hotspot_Pathway <- NA; net_df$Hotspot_Superclass <- NA; net_df$Hotspot_Class <- NA
}
} else {
net_df$Hotspot_Pathway <- NA; net_df$Hotspot_Superclass <- NA; net_df$Hotspot_Class <- NA
}
# --- Step 3: Load CANOPUS Data ---
incProgress(0.5, detail = "Merging CANOPUS data...")
canopus_df <- read.csv(input$canopus_file$datapath, sep = "\t", check.names = FALSE, stringsAsFactors = FALSE)
# Safe renaming mapping
can_cols <- colnames(canopus_df)
can_cols[can_cols == "NPC#pathway"] <- "NPC_Pathway"
can_cols[can_cols == "NPC#superclass"] <- "NPC_Superclass"
can_cols[can_cols == "NPC#class"] <- "NPC_Class"
can_cols[can_cols == "ClassyFire#superclass"] <- "ClassyFire_Superclass"
can_cols[can_cols == "ClassyFire#class"] <- "ClassyFire_Class"
can_cols[can_cols == "ClassyFire#subclass"] <- "ClassyFire_Subclass"
colnames(canopus_df) <- can_cols
# Flexible ID catch for CANOPUS outputs
if("mappingFeatureId" %in% colnames(canopus_df)) {
canopus_df$cluster.index <- as.character(canopus_df$mappingFeatureId)
} else {
id_col <- grep("feature", colnames(canopus_df), ignore.case = TRUE, value = TRUE)[1]
if(is.na(id_col)) id_col <- colnames(canopus_df)[1]
canopus_df$cluster.index <- as.character(canopus_df[[id_col]])
}
merged_df <- left_join(net_df, canopus_df, by = "cluster.index")
# --- Step 4: Calculate Consensus ---
incProgress(0.7, detail = "Calculating Consensus...")
v$logs <- paste0(v$logs, "Propagating NPClassifier AND ClassyFire consensus...\n")
targets <- list(
c("NPC_Pathway", "Hotspot_Pathway", "NPC_Pathway_Consensus", "NPC_Pathway_Score"),
c("NPC_Superclass", "Hotspot_Superclass", "NPC_Superclass_Consensus", "NPC_Superclass_Score"),
c("NPC_Class", "Hotspot_Class", "NPC_Class_Consensus", "NPC_Class_Score"),
c("ClassyFire_Superclass", "Hotspot_CF_Superclass", "ClassyFire_Superclass_Consensus", "ClassyFire_Superclass_Score"),
c("ClassyFire_Class", "Hotspot_CF_Class", "ClassyFire_Class_Consensus", "ClassyFire_Class_Score"),
c("ClassyFire_Subclass", "Hotspot_CF_Subclass", "ClassyFire_Subclass_Consensus", "ClassyFire_Subclass_Score")
)
for(t in targets) {
can_col <- t[1]; hot_col <- t[2]; cons_col <- t[3]; score_col <- t[4]
merged_df[[cons_col]] <- NA
merged_df[[score_col]] <- NA
if(can_col %in% colnames(merged_df)) {
cons_result <- calculate_consensus(merged_df, can_col, hot_col, input$tie_breaker)
if(nrow(cons_result) > 0) {
match_idx <- match(merged_df$componentindex, cons_result$componentindex)
merged_df[[cons_col]] <- cons_result$Consensus[match_idx]
merged_df[[score_col]] <- cons_result$Score[match_idx]
}
# Backfill Singletons
singleton_mask <- merged_df$componentindex == -1 & !is.na(merged_df[[can_col]]) & merged_df[[can_col]] != ""
merged_df[singleton_mask, cons_col] <- merged_df[[can_col]][singleton_mask]
merged_df[singleton_mask, score_col] <- 1.0
}
}
# --- Step 5: Format Final Outputs ---
incProgress(0.9, detail = "Formatting Outputs...")
# Strict CSV Generation (Keeps both Consensus and Score)
v$final_csv <- merged_df %>%
select(cluster.index, contains("_Consensus"), contains("_Score")) %>%
distinct(cluster.index, .keep_all = TRUE)
# Strict GraphML Injection (ONLY injects _Consensus columns)
consensus_cols <- grep("_Consensus", colnames(v$final_csv), value = TRUE)
for (col in consensus_cols) {
idx <- match(V(g)$id, v$final_csv$cluster.index)
vals <- as.character(v$final_csv[[col]][idx])
vals[is.na(vals)] <- ""
g <- set_vertex_attr(g, col, value = vals)
}
v$final_graph <- g
v$logs <- paste0(v$logs, "Analysis Complete! Ready for download.\n")
incProgress(1, detail = "Done!")
})
})
output$status_logs <- renderText({ v$logs })
output$results_table <- renderDT({ req(v$final_csv); datatable(v$final_csv, options = list(pageLength = 10, scrollX = TRUE)) })
output$download_graphml <- downloadHandler(
filename = function() { paste("MolNetEnhancer_Annotated_", Sys.Date(), ".graphml", sep="") },
content = function(file) { write_graph(v$final_graph, file, format = "graphml") }
)
output$download_csv <- downloadHandler(
filename = function() { paste("MolNetEnhancer_Consensus_", Sys.Date(), ".csv", sep="") },
content = function(file) { write.csv(v$final_csv, file, row.names = FALSE) }
)
}
shinyApp(ui = ui, server = server)
runApp()
shiny::runApp()
shiny::runApp()
